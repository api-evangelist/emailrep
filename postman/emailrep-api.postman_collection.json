                      "key": "email"
                    }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "cookie": [],
              "responseTime": null,
              "body": "{\n  \"email\": \"<email>\",\n  \"reputation\": \"low\",\n  \"suspicious\": \"<boolean>\",\n  \"references\": \"<integer>\",\n  \"details\": {\n    \"blacklisted\": \"<boolean>\",\n    \"malicious_activity\": \"<boolean>\",\n    \"malicious_activity_recent\": \"<boolean>\",\n    \"credentials_leaked\": \"<boolean>\",\n    \"credentials_leaked_recent\": \"<boolean>\",\n    \"data_breach\": \"<boolean>\",\n    \"first_seen\": \"<string>\",\n    \"last_seen\": \"<string>\",\n    \"domain_exists\": \"<boolean>\",\n    \"domain_reputation\": \"high\",\n    \"new_domain\": \"<boolean>\",\n    \"days_since_domain_creation\": \"<integer>\",\n    \"suspicious_tld\": \"<boolean>\",\n    \"spam\": \"<boolean>\",\n    \"free_provider\": \"<boolean>\",\n    \"disposable\": \"<boolean>\",\n    \"deliverable\": \"<boolean>\",\n    \"accept_all\": \"<boolean>\",\n    \"valid_mx\": \"<boolean>\",\n    \"spoofable\": \"<boolean>\",\n    \"spf_strict\": \"<boolean>\",\n    \"dmarc_enforced\": \"<boolean>\",\n    \"profiles\": [\n      \"<string>\",\n      \"<string>\"\n    ]\n  },\n  \"summary\": \"<string>\"\n}",
