    {
      "name": "{email}",
      "item": [
        {
          "name": "EmailRep Query Email Reputation",
          "id": "0cb57744-9d47-4610-baae-58ef3d14db41",
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/:email?summary=false",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ":email"
              ],
              "query": [
                {
                  "description": "When `true`, include a human-readable `summary` field in the response.",
                  "key": "summary",
                  "value": "false"
                }
              ],
              "variable": [
                {
                  "id": "3944e267-cd51-4a2a-b19d-772737e645b4",
                  "key": "email",
                  "value": "<email>",
                  "description": "(Required) The email address to query."
                }
              ]
            },
            "description": "Look up reputation, suspiciousness, references, and detailed intelligence signals for an email address. Returns a `reputation` of `high`, `medium`, `low`, or `none`, a boolean `suspicious` flag, a `references` count, and a `details` block covering blacklisting, malicious activity, credential leaks, data breaches, domain reputation, deliverability, MX validity, SPF/DMARC posture, spoofability, free-provider/disposable classification, and online profile observations. Use `summary=true` to additionally receive a human-readable `summary` field."
          },
          "response": [
