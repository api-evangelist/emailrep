        {
          "id": "da0c871e-373d-4de0-9569-4d022a37a4ad",
          "name": "EmailRep Query Email Reputation",
          "request": {
            "name": "EmailRep Query Email Reputation",
            "description": {
              "content": "Look up reputation, suspiciousness, references, and detailed intelligence signals for an email address. Returns a `reputation` of `high`, `medium`, `low`, or `none`, a boolean `suspicious` flag, a `references` count, and a `details` block covering blacklisting, malicious activity, credential leaks, data breaches, domain reputation, deliverability, MX validity, SPF/DMARC posture, spoofability, free-provider/disposable classification, and online profile observations. Use `summary=true` to additionally receive a human-readable `summary` field.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ":email"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "summary",
                  "value": "false",
                  "description": "When `true`, include a human-readable `summary` field in the response."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<email>",
                  "key": "email",
                  "description": "(Required) The email address to query."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
