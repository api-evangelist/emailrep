    {
      "id": "f3463e37-1703-4468-aeb1-72b2f61b49d7",
      "name": "Reports",
      "description": {
        "content": "Report email addresses as malicious so the reputation graph picks up the signal.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "5f0bce22-d158-47c1-8393-f2c57ee9a09d",
          "name": "EmailRep Report Email",
          "request": {
            "name": "EmailRep Report Email",
            "description": {
              "content": "Report an email address as exhibiting malicious behavior so the EmailRep reputation graph picks up the signal. Requires an API key. Submit one or more `tags` (such as `bec`, `maldoc`, `phishing`, `account_takeover`, `spam`), an optional human-readable `description`, the `timestamp` when the activity was observed (Unix epoch seconds, defaults to now), and an optional `expires` window in hours during which the address should be treated as risky.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "report"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"<email>\",\n  \"tags\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"description\": \"<string>\",\n  \"timestamp\": \"<long>\",\n  \"expires\": \"<integer>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "12be147e-e2f4-46e1-ac94-53d0323ff810",
              "name": "Report accepted.",
              "originalRequest": {
                "url": {
                  "path": [
                    "report"
                  ],
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "query": [],
                  "variable": []
                },
