                    },
                    "key": "Key",
                    "value": "<API Key>"
                  },
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"attacker@example.com\",\n  \"tags\": [\n    \"bec\",\n    \"maldoc\"\n  ],\n  \"description\": \"Phishing email impersonating the CEO with a malicious attachment.\",\n  \"timestamp\": 1748563200,\n  \"expires\": 168\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
